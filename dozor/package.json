{
  "name": "@kharko/dozor",
  "version": "1.0.0",
  "description": "Lightweight session recording SDK for Kharko Dozor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kolia-zamnius/kharko-dozor.git",
    "directory": "dozor"
  },
  "homepage": "https://kharko-dozor.vercel.app",
  "bugs": {
    "url": "https://github.com/kolia-zamnius/kharko-dozor/issues"
  },
  "keywords": [
    "session-recording",
    "session-replay",
    "rrweb",
    "analytics",
    "monitoring",
    "observability"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@rrweb/rrweb-plugin-console-record": "2.0.0-alpha.20",
    "rrweb": "2.0.0-alpha.20"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
